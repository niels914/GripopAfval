# Supabase — projectinstellingen > API
NEXT_PUBLIC_SUPABASE_URL=https://jouw-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=jouw-anon-key

# Resend — bevestigingsmails + scanrapport + interne notificaties
# Verifieer het verzenddomein (gripopafval.nl) in Resend: SPF + DKIM.
RESEND_API_KEY=re_xxxxxxxxxxxx
# Afzender zoals die in de inbox verschijnt (domein moet geverifieerd zijn)
RESEND_FROM="GripOpAfval <noreply@gripopafval.nl>"
# Ontvanger van interne "nieuwe lead"-notificaties
LEAD_NOTIFY_EMAIL=niels@kplusv.nl

# Anthropic — adviesbot op /advies (zonder key toont de bot een nette fallback)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Basis-URL van de site (voor sitemap/OG/maillinks); zet op je productie-domein
NEXT_PUBLIC_SITE_URL=https://gripopafval.nl
